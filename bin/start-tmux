#!/bin/bash
set -e

CODE_DIR="${PROJECTS:-$HOME/Documents/Code}"
SESSION="dev"
CONFIG_FILE="$HOME/.config/tmux/projects"
MAX_TABS=9

show_help() {
    echo "Usage: start-tmux [OPTIONS]"
    echo ""
    echo "Start a tmux session with project tabs."
    echo ""
    echo "Options:"
    echo "  -a, --all     Open all directories in $CODE_DIR"
    echo "  -h, --help    Show this help message"
    echo ""
    echo "By default, opens projects listed in ~/.config/tmux/projects (max $MAX_TABS)."
    echo "Each line should be a full path (~ is expanded). Tab name is the directory name."
}

# Parse arguments
USE_ALL=false
while [[ $# -gt 0 ]]; do
    case $1 in
        -a|--all)
            USE_ALL=true
            shift
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            echo "Unknown option: $1"
            show_help
            exit 1
            ;;
    esac
done

# Build project list (stores full paths)
projects=()

if [[ "$USE_ALL" == true ]]; then
    # All directories in CODE_DIR
    for d in "$CODE_DIR"/*/; do
        [[ -d "$d" ]] && projects+=("${d%/}")
    done
elif [[ -f "$CONFIG_FILE" ]]; then
    # Read full paths from config file, limit to MAX_TABS
    while IFS= read -r line || [[ -n "$line" ]]; do
        # Skip empty lines and comments
        [[ -z "$line" || "$line" =~ ^# ]] && continue
        # Expand ~ to $HOME
        path="${line/#\~/$HOME}"
        # Only add if directory exists
        if [[ -d "$path" ]]; then
            projects+=("$path")
            # Stop at MAX_TABS
            [[ ${#projects[@]} -ge $MAX_TABS ]] && break
        else
            echo "Warning: $path not found, skipping"
        fi
    done < "$CONFIG_FILE"
else
    echo "No config file at $CONFIG_FILE - run 'dot' to create it"
fi

# Kill existing session if running
tmux kill-session -t $SESSION 2>/dev/null || true

# Create session with main window
tmux new-session -d -s $SESSION -n "code" -c "$CODE_DIR"

# Create windows for projects (if any found)
if [[ ${#projects[@]} -eq 0 ]]; then
    echo "No projects configured - edit ~/.config/tmux/projects to add some"
else
    for path in "${projects[@]}"; do
        name="$(basename "$path")"
        tmux new-window -t $SESSION -n "$name" -c "$path"
    done
fi

# Select staging window
tmux select-window -t "$SESSION:0"

# Attach to session
tmux attach -t $SESSION
